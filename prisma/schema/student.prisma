model Student {
  id                 String @id @default(cuid())
  userId             String @unique
  campusDepartmentId String
  roll               String
  session            String
  semester           Int
  shift              Shift

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user             User             @relation("StudentUser", fields: [userId], references: [id])
  campusDepartment CampusDepartment @relation(fields: [campusDepartmentId], references: [id])

  marks Mark[]

  @@unique([campusDepartmentId, roll, session])
  @@index([campusDepartmentId])
}
