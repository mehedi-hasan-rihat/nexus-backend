model Campus {
  id         String   @id @default(cuid())
  campusName String
  campusCode String   @unique
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdById String
  createdBy   User    @relation("CampusCreatedBy", fields: [createdById], references: [id])

  departments CampusDepartment[]

  @@index([createdById])
}
