model Subject {
  id                 String     @id @default(cuid())
  campusDepartmentId String
  name               String
  code               String     @unique
  semester           Int
  maxMarks           Float
  credit             CreditType

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  campusDepartment CampusDepartment @relation(fields: [campusDepartmentId], references: [id])
  marks            Mark[]

  @@index([campusDepartmentId])
}
