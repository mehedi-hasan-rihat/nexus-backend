model Campus {
  id         Int      @id @default(autoincrement())
  campusName String
  campusCode String   @unique
  address    String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  createdById Int
  createdBy   User    @relation("CampusCreatedBy", fields: [createdById], references: [id])

  departments CampusDepartment[]
  teachers    Teacher[]
  students    Student[]
  subjects    Subject[]
  marks       Mark[]

  @@index([createdById])
}
